# Required: API key for authenticating proxy requests (sent via X-API-Key header)
API_KEY=your-secret-api-key-here

# Optional: Comma-separated list of allowed target hostnames (supports * wildcard).
# Leave unset to allow any host.
# Example: ALLOWED_HOSTS=api.example.com,*.myservice.io
ALLOWED_HOSTS=

# Optional: Comma-separated allowed CORS origins.
# Use * to allow any origin (default), or restrict to specific origins.
# Example: ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=*

# Optional: Proxy request timeout in milliseconds (default: 30000)
PROXY_TIMEOUT=30000

# Optional: Set to "false" to disable upstream SSL certificate verification (default: true)
VERIFY_SSL=true

# Optional: Maximum allowed Content-Length in bytes (default: 10485760 = 10MB)
MAX_BODY_SIZE=10485760

# Optional: Set to "true" to include upstream error messages in 502 responses
DEBUG=false
